/* settings.wxss */
.container {
  padding: 20rpx;
  background: #f5f6fa;
  min-height: 100vh;
}
.setting-item {
  margin-bottom: 24rpx;
}
.picker {
  padding: 10rpx;
  border: 1px solid #cccccc;
  border-radius: 5rpx;
}
button {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
}
button::after {
  border: none;
}

.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
}
.employee-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.employee-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #f0f4ff 0%, #e8ecff 100%);
  border-radius: 40rpx;
  border: 2rpx solid #e0e6ff;
  transition: all 0.2s ease;
}
.employee-item:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, #e0e6ff 0%, #d4ddff 100%);
}
.employee-item .employee-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}
.employee-item .employee-name {
  font-size: 28rpx;
  color: #1e3a8a;
  font-weight: 500;
}
.employee-item .load-icon {
  font-size: 24rpx;
  color: #818cf8;
}
.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 60rpx;
  background: #f8f9fc;
  border-radius: 16rpx;
}
.empty-tip::before {
  content: '👥';
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}