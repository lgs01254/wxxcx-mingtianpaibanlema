.admin-container {
  background: #f5f6fa;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 头部 */
.header-bar {
  background: #fff;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 20rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2c3e50;
}
.month-selector {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.arrow-btn {
  font-size: 28rpx;
  color: #007AFF;
  padding: 10rpx 16rpx;
}
.month-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* 卡片通用 */
.employee-card,
.schedule-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  border-left: 6rpx solid #007AFF;
  padding-left: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.select-all {
  font-size: 26rpx;
  color: #007AFF;
}

.batch-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.selected-count {
  font-size: 26rpx;
  color: #666;
}

.batch-btn {
  font-size: 26rpx;
  color: #fff;
  background: #e74c3c;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.batch-btn.cancel {
  background: #999;
}
.schedule-card .month-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}
.schedule-card .month-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  min-width: 160rpx;
  text-align: center;
}
.schedule-card .arrow-btn {
  font-size: 32rpx;
  color: #007AFF;
  padding: 10rpx 20rpx;
}

/* 班次选择器 */
.shift-selector {
  padding: 16rpx 20rpx;
  background: #f8f9fc;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}
.shift-selector-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.shift-selector-scroll {
  white-space: nowrap;
}
.shift-selector-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}
.shift-type-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #333;
  border: 3rpx solid transparent;
  white-space: nowrap;
}
.shift-type-btn.active {
  background: #007AFF;
  color: #fff;
}
.color-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}
.shift-cell.selectable {
  cursor: pointer;
}
.shift-cell.selectable:active {
  opacity: 0.7;
}

/* 员工输入 */
.employee-input-row {
  display: flex;
  margin-bottom: 20rpx;
  gap: 20rpx;
}
.employee-input {
  flex: 1;
  height: 72rpx;
  background: #f8f9fc;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid #e9ecf1;
}
.add-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 36rpx;
  background: #007AFF;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.employee-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}
.employee-tag {
  background: #f0f4ff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid #e0e6ff;
}
.employee-tag:active {
  background: #e0e6ff;
}
.employee-name {
  font-size: 28rpx;
  color: #1e3a8a;
  font-weight: 500;
}
.employee-arrow {
  font-size: 32rpx;
  color: #999;
}
.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ccc;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  background: #fff;
}
.checkbox-inner {
  font-size: 24rpx;
  color: #007AFF;
}

/* 小按钮 */
.mini {
  font-size: 22rpx !important;
  padding: 4rpx 16rpx !important;
  border-radius: 20rpx !important;
  line-height: 1.8;
  margin: 0;
}
.share-btn.mini {
  background: #007AFF;
  color: #fff;
  border: none;
}
.delete-btn.mini {
  background: #fff;
  color: #e74c3c;
  border: 1rpx solid #e74c3c;
}
.empty-tip {
  color: #aaa;
  font-size: 28rpx;
  text-align: center;
  padding: 40rpx;
}

/* ========== 表格核心布局 ========== */
.table-container {
  display: flex;
  position: relative;
}

/* 左侧固定姓名列 */
.fixed-name-column {
  position: sticky;
  left: 0;
  z-index: 10;
  width: 130rpx;
  min-width: 130rpx;
  background: #fff;
  border-right: 2rpx solid #eee;
  display: flex;
  flex-direction: column;
}
.fixed-cell {
  width: 130rpx;
  min-width: 130rpx;
  height: 80rpx;
  padding: 0 12rpx;
  text-align: center;
  font-size: 26rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-bottom: 1rpx solid #f4f5f7;
  font-weight: 600;
  flex-shrink: 0;
}
.fixed-cell.header-cell {
  background: #f9fafc;
  font-weight: 600;
  color: #556;
}

/* 右侧可滚动区域 */
.table-scroll {
  flex: 1;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

/* 表头 */
.table-header {
  display: flex;
  align-items: stretch;
  background: #f9fafc;
  border-bottom: 2rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

/* 每一行 */
.table-row {
  display: flex;
  align-items: stretch;
  border-bottom: 1rpx solid #f4f5f7;
}
.table-row:last-child {
  border-bottom: none;
}

/* 通用单元格 */
.cell {
  width: 120rpx;
  min-width: 120rpx;
  height: 80rpx;
  padding: 0 12rpx;
  text-align: center;
  font-size: 26rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-right: 1rpx solid #f0f2f5;
  flex-shrink: 0;
  white-space: nowrap;
}
.cell:last-child {
  border-right: none;
}
.header-cell {
  font-weight: 600;
  color: #556;
}
.header-cell.date-cell.weekend {
  background-color: #fff9e6;
}

/* 日期表头 */
.date-cell {
  font-size: 22rpx;
}
.header-day {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.header-weekday {
  font-size: 20rpx;
  color: #999;
}

/* 班次格子 */
.shift-cell {
  background: #fcfcfc;
  color: #999;
  transition: 0.2s;
}
.shift-cell:active {
  opacity: 0.7;
}

/* 操作列 - 固定在右侧 */
.action-cell {
  position: sticky;
  right: 0;
  z-index: 5;
  background: #fff;
  border-left: 2rpx solid #eee;
  width: 140rpx;
  min-width: 140rpx;
  flex-direction: row;
  gap: 10rpx;
}
.table-header .action-cell {
  background: #f9fafc;
  z-index: 6;
}

.share-icon-btn,
.delete-icon-btn {
  background: transparent;
  border: none;
  font-size: 36rpx;
  padding: 0 10rpx;
  line-height: 1;
}
.delete-icon-btn {
  color: #e74c3c;
}

/* ========== 弹窗 ========== */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}
.shift-popup {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  width: 80%;
  z-index: 101;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.15);
}
.popup-title {
  text-align: center;
  margin-bottom: 30rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}
.shift-options {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}
.shift-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f5f7fa;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #333;
}
.shift-option:active {
  background: #e9ecf1;
}
.shift-option.clear {
  background: #fff0f0;
  color: #e74c3c;
}
.color-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #007AFF;
}
.popup-cancel {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

/* 员工操作菜单弹窗 */
.employee-menu-popup {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  width: 80%;
  z-index: 101;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.15);
}
.menu-title {
  text-align: center;
  margin-bottom: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f7fa;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  border: none;
  width: 100%;
  box-sizing: border-box;
}
.menu-item::after {
  display: none;
}
.menu-item:active {
  background: #e9ecf1;
}
.menu-item.delete {
  background: #fff0f0;
  color: #e74c3c;
}
.menu-cancel {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

/* 操作按钮区域 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 30rpx;
}

.excel-import-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
  color: #fff;
  border-radius: 40rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
}

.excel-import-btn:active {
  opacity: 0.8;
}

.excel-import-btn[disabled] {
  opacity: 0.6;
  background: linear-gradient(135deg, #999 0%, #aaa 100%);
}

.share-all-btn {
  background: #007AFF;
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
  margin-top: 0;
}

/* ========== 工作表选择弹窗 ========== */
.sheet-selector-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.sheet-selector-header {
  text-align: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.sheet-selector-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.sheet-selector-subtitle {
  font-size: 24rpx;
  color: #999;
}

.sheet-selector-list {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 20rpx;
}

.sheet-selector-all {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.sheet-selector-all text {
  font-size: 28rpx;
  color: #666;
  margin-left: 12rpx;
}

.sheet-tag {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f0f4ff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.sheet-tag:active {
  background: #e0e6ff;
}

.sheet-name {
  font-size: 28rpx;
  color: #1e3a8a;
  margin-left: 12rpx;
  flex: 1;
}

.sheet-status {
  font-size: 24rpx;
  color: #999;
}

.sheet-selector-actions {
  display: flex;
  gap: 20rpx;
}

.sheet-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.sheet-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.sheet-btn.confirm {
  background: #007AFF;
  color: #fff;
}
